# Runtime caches and editor lock files — never auto-add to source.
.config/zsh/.zcompdump*
.config/zsh/.zcompcache/**
.config/zsh/.#*
.config/zsh/.claude/**
.config/zsh/.zsh_history

# Emacs byte-compile artifacts — never auto-add to source.
.config/emacs/*.elc
.config/emacs/eln-cache/**

# Claude skills: no longer managed by chezmoi (edited live, not via dotfiles).
.claude/skills
.claude/skills/**

# iTerm2 shell integration: auto-updated by iTerm2 itself → perpetual drift.
.config/zsh/.iterm2
.config/zsh/.iterm2/**
.config/zsh/.iterm2_shell_integration.zsh

# gh CLI config: managed by `gh auth` (old token auth is obsolete).
.config/gh
.config/gh/**

# chezmoi's own state DB: machine-specific binary, never track.
.config/chezmoi/chezmoistate.boltdb

# Home-only files: excluded on work machines (profile = "work").
{{ if eq .profile "work" }}
.ssh
.ssh/**
.authinfo
.mbsyncrc
.msmtprc
{{ end }}

# Work-only secrets: excluded on home machines (profile = "home").
{{ if eq .profile "home" }}
.config/zsh/atlassian_token.zsh
.config/zsh/google_geocoding_api_key.zsh
.config/zsh/nsl_id2.zsh
.config/zsh/nsl_secret2.zsh
.config/zsh/boston_tile_coverage_auth.zsh
.config/zsh/boston_tile_source_v2_auth.zsh
.config/zsh/irp_api_key.zsh
{{ end }}
