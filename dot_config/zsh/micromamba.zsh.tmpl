# Micromamba init. Must be LAST — replaces conda/mamba init block.
# !! Contents managed by 'micromamba shell init' !!

export MAMBA_EXE='{{ .chezmoi.homeDir }}/.local/bin/micromamba'
export MAMBA_ROOT_PREFIX='{{ .chezmoi.homeDir }}/micromamba'
__mamba_setup="$("$MAMBA_EXE" shell hook --shell zsh --root-prefix "$MAMBA_ROOT_PREFIX" 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__mamba_setup" 2>/dev/null
else
    alias micromamba="$MAMBA_EXE"
fi
unset __mamba_setup
