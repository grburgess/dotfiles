# Third-party tool init. Each block guarded so a missing binary doesn't break the shell.

# iTerm2 shell integration (host-installed).
[[ -e "${HOME}/.config/zsh/.iterm2_shell_integration.zsh" ]] && source "${HOME}/.config/zsh/.iterm2_shell_integration.zsh"

# mise — runtime version manager.
command -v mise >/dev/null 2>&1 && eval "$(mise activate zsh)"

# zoxide — smarter cd.
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"

# direnv — per-directory env.
command -v direnv >/dev/null 2>&1 && eval "$(direnv hook zsh)"

# History substring search keybinds — only if the plugin loaded the widget,
# otherwise bindkey creates a phantom widget that fast-syntax-highlighting then warns about.
if zle -la history-substring-search-up >/dev/null 2>&1; then
    bindkey '^[[A' history-substring-search-up
    bindkey '^[[B' history-substring-search-down
    bindkey -M vicmd 'k' history-substring-search-up
    bindkey -M vicmd 'j' history-substring-search-down
fi

{{ if eq .chezmoi.os "darwin" }}
# Google Cloud SDK (installed via Homebrew Cask).
if command -v brew >/dev/null 2>&1; then
    gcloud_sdk="$(brew --prefix)/share/google-cloud-sdk"
    [[ -f "${gcloud_sdk}/path.zsh.inc" ]] && source "${gcloud_sdk}/path.zsh.inc"
    [[ -f "${gcloud_sdk}/completion.zsh.inc" ]] && source "${gcloud_sdk}/completion.zsh.inc"
    unset gcloud_sdk
fi
{{ end }}
