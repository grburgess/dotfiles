#
# Thin orchestrator. Logic lives in the modules below.

# Non-interactive / dumb terminal short-circuit.
[[ $TERM == "dumb" ]] && unsetopt zle && PS1='$ ' && return

zsh_dir="${HOME}/.config/zsh"

source "${zsh_dir}/env.zsh"          # PATH + env vars
source "${zsh_dir}/options.zsh"      # setopt / history / bindkey
source "${zsh_dir}/plugins.zsh"      # zinit + plugins
source "${zsh_dir}/completion.zsh"   # compinit + zstyle (needs zinit loaded)
source "${zsh_dir}/fzf.zsh"          # FZF_* + shell integration
source "${zsh_dir}/tools.zsh"        # mise / zoxide / direnv / iterm2 / gcloud
source "${zsh_dir}/functions.zsh"    # shmux, periodic_remote_rsync
source "${zsh_dir}/emacs.zsh"        # emacsclient wrappers
source "${zsh_dir}/alias.zsh"        # aliases
source "${zsh_dir}/highlight.zsh"    # syntax-highlight styles

# Secrets — rendered from 1Password by chezmoi (private_* prefix → 0600 perms).
source "${zsh_dir}/github_token.zsh"
source "${zsh_dir}/wandb.zsh"
source "${zsh_dir}/hf_token.zsh"
source "${zsh_dir}/boston_tile_source_v2_auth.zsh"
source "${zsh_dir}/boston_tile_coverage_auth.zsh"
source "${zsh_dir}/google_geocoding_api_key.zsh"
source "${zsh_dir}/nsl_id2.zsh"
source "${zsh_dir}/nsl_secret2.zsh"
source "${zsh_dir}/atlassian_token.zsh"

# Mambaforge and micromamba init must come last.
source "${zsh_dir}/mambaforge.zsh"
source "${zsh_dir}/micromamba.zsh"

unset zsh_dir
