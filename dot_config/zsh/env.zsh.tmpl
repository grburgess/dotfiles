# Environment variables and PATH.
# Sourced first so subsequent modules can rely on PATH.

# ----- PATH -----
{{ if eq .chezmoi.os "darwin" }}
export PATH="/opt/homebrew/bin:$PATH"
export PATH="/usr/local/opt/coreutils/libexec/gnubin:$PATH"
export PATH="${PATH}:${HOME}/.cargo/bin"
export PATH="${PATH}:${HOME}/.local/bin"
{{ else if eq .chezmoi.os "linux" }}
export PATH="/usr/local/sbin:/usr/local/bin:${PATH}"
export PATH="${PATH}:${HOME}/.local/bin"
{{ end }}

# ----- Editor -----
export EDITOR='emacs'

# ----- Python / venv -----
export WORKON_HOME="${HOME}/.environs"
{{ if and (eq .chezmoi.os "linux") (ne .chezmoi.osRelease.id "raspbian") }}
export VIRTUALENVWRAPPER_PYTHON=/usr/bin/python3
[[ -f "${HOME}/.local/bin/virtualenvwrapper.sh" ]] && source "${HOME}/.local/bin/virtualenvwrapper.sh"
{{ end }}

# ----- Scientific stack -----
export ATOMDB="${HOME}/.threeml/atomdb"
export CMDSTAN="${HOME}/.cmdstan/cmdstan"
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export HDF5_DISABLE_VERSION_CHECK=1

{{ if eq .chezmoi.os "darwin" }}
export HDF5_DIR="$(brew --prefix hdf5)"
export DYLD_LIBRARY_PATH="${DYLD_LIBRARY_PATH}:${HOME}/sw/lib"

# M1/Apple-silicon BLAS / Numba threads (P-core count).
export NUMBA_NUM_THREADS=8
export OPENBLAS_NUM_THREADS=8
export NUMBA_THREADING_LAYER=omp
{{ end }}

# ----- MLflow tracking server (Moodys internal, not a credential) -----
export MLFLOW_TRACKING_URI="https://mlflow.ml-cape.com"

# ----- COW default docker image -----
export COW_DEFAULT_DOCKER_IMAGES="us-docker.pkg.dev/devops-tools-295c/us-docker/cnvrg:ml_dev-2026.21.1"

# ----- iTerm / tmux -----
export ITERM_ENABLE_SHELL_INTEGRATION_WITH_TMUX=YES

# ----- ls colors -----
export LS_COLORS="*.rsp=32:*.rsp2=32:*.h5=34:*.pha=33:*.fits=33;01:*.py=32;01:*.ipynb=36"
